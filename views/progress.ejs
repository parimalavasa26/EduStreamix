<script>
  // Set timestamps
  const now = new Date();
  const fmt = d => d.toLocaleString('en-IN', { dateStyle: 'medium', timeStyle: 'short' });
  document.getElementById('lastUpdated').textContent = fmt(now);
  document.getElementById('footerTime').textContent = fmt(now);

  // Copy URL helper
  function copyUrl(id) {
    const text = document.getElementById(id).textContent;
    navigator.clipboard.writeText(text).then(() => {
      alert('URL copied to clipboard!');
    });
  }

  // Animate stat cards on load
  document.querySelectorAll('.stat-card').forEach((el, i) => {
    el.style.animationDelay = (i * 0.08) + 's';
    el.classList.add('stat-anim');
  });
</script>

