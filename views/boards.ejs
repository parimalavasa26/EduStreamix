<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Select your board — SSC, CBSE, or ICSE — on EduStreamix." />
  <title>Select Board — EduStreamix</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body class="step-body">

  <nav class="navbar scrolled" id="navbar">
    <a href="/" class="nav-brand">
      <span class="brand-icon">🎓</span>
      <span class="brand-text">EduStreami<span class="brand-x">x</span></span>
    </a>
    <div class="nav-links">
      <a href="/">Home</a>
      <div class="nav-lang-picker">
        <button class="lang-picker-btn">
          <span id="current-lang-name">English</span>
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
        </button>
        <div class="lang-dropdown">
          <a href="#" class="lang-option" onclick="changeAppLang('English')"><span>English</span></a>
          <a href="#" class="lang-option" onclick="changeAppLang('Hindi')"><span>Hindi</span> <span>हिंदी</span></a>
          <a href="#" class="lang-option" onclick="changeAppLang('Telugu')"><span>Telugu</span> <span>తెలుగు</span></a>
          <a href="#" class="lang-option" onclick="changeAppLang('Kannada')"><span>Kannada</span> <span>ಕನ್ನಡ</span></a>
          <a href="#" class="lang-option" onclick="changeAppLang('Tamil')"><span>Tamil</span> <span>தமிழ்</span></a>
          <a href="#" class="lang-option" onclick="changeAppLang('Malayalam')"><span>Malayalam</span> <span>മലയാളం</span></a>
          <a href="#" class="lang-option" onclick="changeAppLang('Odia')"><span>Odia</span> <span>ଓଡ଼ିଆ</span></a>
        </div>
      </div>
    </div>
  </nav>

  <main class="step-main">
    <div class="step-container">

      <div class="step-progress" id="step-progress">
        <div class="step-dot active" data-step="1">
          <span class="step-dot-inner">1</span>
          <span class="step-dot-label">Board</span>
        </div>
        <div class="step-line"></div>
        <div class="step-dot" data-step="2">
          <span class="step-dot-inner">2</span>
          <span class="step-dot-label">Subjects</span>
        </div>
      </div>

      <div class="step-header">
        <a href="/" class="back-step-link" id="back-to-home">← Back to Home</a>
        <h1 class="step-title">Class 9 Boards</h1>
        <p class="step-subtitle">Select your education board to see Class 9 subjects</p>
      </div>

      <div class="board-grid" id="board-grid">
        <a href="/subjects?grade=<%= selectedGrade %>&board=SSC" class="board-card" id="board-card-ssc">
          <div class="board-card-glow"></div>
          <span class="board-icon">🏫</span>
          <h3 class="board-card-title" data-i18n="SSC">SSC</h3>
          <p class="board-card-label" data-i18n="State Board">State Board</p>
          <span class="board-card-arrow">→</span>
        </a>
        <a href="/subjects?grade=<%= selectedGrade %>&board=CBSE" class="board-card" id="board-card-cbse">
          <div class="board-card-glow"></div>
          <span class="board-icon">📘</span>
          <h3 class="board-card-title" data-i18n="CBSE">CBSE</h3>
          <p class="board-card-label" data-i18n="Central Board">Central Board</p>
          <span class="board-card-arrow">→</span>
        </a>
        <a href="/subjects?grade=<%= selectedGrade %>&board=ICSE" class="board-card" id="board-card-icse">
          <div class="board-card-glow"></div>
          <span class="board-icon">🎓</span>
          <h3 class="board-card-title" data-i18n="ICSE">ICSE</h3>
          <p class="board-card-label" data-i18n="Indian Certificate">Indian Certificate</p>
          <span class="board-card-arrow">→</span>
        </a>
      </div>

    </div>
  </main>

  <footer class="footer">
    <div class="footer-inner">
      <span class="footer-brand">🎓 EduStreami<span class="brand-x">x</span></span>
      <span class="footer-copy">&copy; 2026 EduStreamix. Built for learners.</span>
    </div>
  </footer>

  <script src="/js/i18n.js"></script>
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const display = document.getElementById('nav-lang-display');
      if (display) {
        const lang = localStorage.getItem('appLang') || 'English';
        const languageNames = {
          'English': 'English',
          'Hindi': 'हिंदी',
          'Telugu': 'తెలుగు',
          'Tamil': 'தமிழ்',
          'Kannada': 'ಕನ್ನಡ',
          'Malayalam': 'മലയാളം'
        };
        display.textContent = languageNames[lang] || lang;
      }
    });
  </script>
</body>
</html>
