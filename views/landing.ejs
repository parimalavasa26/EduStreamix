<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="EduStreamix — Your focused, distraction-free learning platform." />
  <title>EduStreamix — Distraction-Free Learning</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Outfit:wght@400;500;600;700;800&family=Permanent+Marker&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body class="landing-body">

  <nav class="navbar" id="navbar">
    <a href="/" class="nav-brand">
      <span class="brand-icon">🎓</span>
      <span class="brand-text">EduStreami<span class="brand-x">x</span></span>
    </a>
    <div class="nav-links">
      <a href="#features">Why EduStreamix</a>
    </div>
  </nav>

  <!-- LOGO HEADER BANNER -->
  <section class="logo-banner" id="logo-banner">
    <div class="logo-banner-inner">
      <div class="logo-banner-left">
        <img src="/uploads/logos/Osmania_logo.jpg" alt="Osmania University" class="partner-logo partner-logo-left" />
      </div>
      <div class="logo-banner-center">
        <h1 class="brand-title-marker">
          <span class="marker-edu">EDU</span><span class="marker-stream">STREAMI</span><span class="marker-x">X</span>
        </h1>
        <div class="grade-badge">For Grade 8</div>
      </div>
      <div class="logo-banner-right">
        <img src="/uploads/logos/otbi_logo.jpg" alt="Osmania Technology Business Incubator" class="partner-logo partner-logo-right" />
      </div>
    </div>
  </section>

  <!-- HERO -->
  <section class="hero" id="hero">

    <div class="hero-content">
      <p class="hero-tagline">The distraction-free platform</p>
      <p class="hero-subtitle">
        EduStreamix is your focused learning space—where content is organized,
        distractions are minimized, and learning becomes effective.
      </p>
      <a href="/boards?grade=8" class="hero-btn" id="dive-into-learning-btn">
        <span>Dive into Learning</span>
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M4 10h12M12 6l4 4-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
    </div>
  </section>

  <!-- FEATURES / WHY EDUSTREAMIX -->
  <section class="features" id="features">
    <h2 class="section-title">Why EduStreamix?</h2>
    <p class="section-subtitle">Everything you need, nothing you don't.</p>
    <div class="features-grid">
      <div class="feature-card" id="feature-1">
        <div class="feature-icon-wrap"><div class="feature-icon">🛡️</div></div>
        <h3>Distraction-Free</h3>
        <p>No ads, no recommendations, no rabbit holes. Videos play right here — clean, focused, and controlled.</p>
      </div>
      <div class="feature-card" id="feature-3">
        <div class="feature-icon-wrap"><div class="feature-icon">📚</div></div>
        <h3>Organized Content</h3>
        <p>Subjects, chapters, and topics — all structured so you never lose your way.</p>
      </div>
    </div>
  </section>

  <footer class="footer">
    <div class="footer-inner">
      <span class="footer-brand">🎓 EduStreami<span class="brand-x">x</span></span>
      <span class="footer-copy">&copy; 2026 EduStreamix. Built for learners.</span>
    </div>
  </footer>

  <script>
    window.addEventListener('scroll', () => {
      document.getElementById('navbar').classList.toggle('scrolled', window.scrollY > 40);
    });
  </script>
</body>
</html>
