<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin - Upload PDF Textbook</title>
  <link rel="stylesheet" href="/css/style.css">
  <style>
    .admin-container {
      max-width: 600px;
      margin: 50px auto;
      padding: 30px;
      background: var(--card-bg);
      border-radius: 12px;
      box-shadow: 0 4px 15px rgba(0,0,0,0.1);
    }
    .admin-container h1 {
      margin-bottom: 20px;
      color: var(--text-color);
    }
    .form-group {
      margin-bottom: 15px;
    }
    .form-group label {
      display: block;
      margin-bottom: 5px;
      color: var(--text-color);
      font-weight: 500;
    }
    .form-group input, .form-group select {
      width: 100%;
      padding: 10px;
      border-radius: 8px;
      border: 1px solid rgba(0,0,0,0.1);
      font-size: 1rem;
    }
    .btn-upload {
      width: 100%;
      padding: 12px;
      background: var(--primary-color);
      color: white;
      border: none;
      border-radius: 8px;
      font-size: 1rem;
      font-weight: 600;
      cursor: pointer;
      margin-top: 10px;
    }
    .btn-upload:hover {
      background: var(--primary-hover);
    }
    .status-msg {
      margin-top: 15px;
      padding: 10px;
      border-radius: 8px;
      display: none;
    }
    .status-success {
      background: rgba(46, 213, 115, 0.1);
      color: #2ed573;
    }
    .status-error {
      background: rgba(255, 71, 87, 0.1);
      color: #ff4757;
    }
  </style>
</head>
<body class="study-body">

  <nav class="navbar scrolled" id="navbar">
    <a href="/" class="nav-brand">
      <span class="brand-icon">🎓</span>
      <span class="brand-text">EduStreami<span class="brand-x">x</span></span>
    </a>
  </nav>

  <main>
    <div class="admin-container">
      <h1>📤 Upload Textbook PDF</h1>
      <form id="uploadForm">
        <div class="form-group">
          <label>Grade / Class</label>
          <input type="number" id="grade" required placeholder="e.g. 8">
        </div>
        <div class="form-group">
          <label>Board</label>
          <input type="text" id="board" required placeholder="e.g. CBSE">
        </div>
        <div class="form-group">
          <label>Subject</label>
          <input type="text" id="subject" required placeholder="e.g. Mathematics">
        </div>
        <div class="form-group">
          <label>Chapter Name</label>
          <input type="text" id="chapterName" required placeholder="e.g. Number Systems">
        </div>
        <div class="form-group">
          <label>PDF File</label>
          <input type="file" id="pdfFile" accept="application/pdf" required>
        </div>
        
        <button type="submit" class="btn-upload" id="uploadBtn">Upload PDF</button>
      </form>
      <div id="statusMessage" class="status-msg"></div>
    </div>

    <div class="admin-container" style="margin-top: 30px;">
      <h1>🔗 Link YouTube Video</h1>
      <form id="linkYoutubeForm">
        <div class="form-group">
          <label>Grade / Class</label>
          <input type="number" id="ytGrade" required placeholder="e.g. 8">
        </div>
        <div class="form-group">
          <label>Board</label>
          <input type="text" id="ytBoard" required placeholder="e.g. CBSE">
        </div>
        <div class="form-group">
          <label>Subject</label>
          <input type="text" id="ytSubject" required placeholder="e.g. Mathematics">
        </div>
        <div class="form-group">
          <label>Chapter Name</label>
          <input type="text" id="ytChapterName" required placeholder="e.g. Number Systems">
        </div>
        <div class="form-group">
          <label>Language</label>
          <select id="ytLanguage">
            <option value="English">English</option>
            <option value="Hindi">Hindi</option>
            <option value="Telugu">Telugu</option>
            <option value="Tamil">Tamil</option>
            <option value="Kannada">Kannada</option>
            <option value="Malayalam">Malayalam</option>
          </select>
        </div>
        <div class="form-group">
          <label>YouTube URL or ID</label>
          <input type="text" id="youtubeUrl" required placeholder="e.g. https://www.youtube.com/watch?v=...">
        </div>
        
        <button type="submit" class="btn-upload" id="linkBtn">Link Video</button>
      </form>
      <div id="ytStatusMessage" class="status-msg"></div>
    </div>

    <div class="admin-container" style="margin-top: 30px;">
      <h1>⚙️ Global Settings</h1>
      <form id="settingsForm">
        <div class="form-group">
          <label>YouTube API Key</label>
          <input type="password" id="ytApiKeyInput" placeholder="Enter your Google Cloud API Key">
        </div>
        <button type="submit" class="btn-upload" id="saveSettingsBtn">Save Settings</button>
      </form>
      <div id="settingsStatusMessage" class="status-msg"></div>
    </div>
  </main>

  <script>
    document.getElementById('uploadForm').addEventListener('submit', async (e) => {
      e.setLayout = e.preventDefault();
      
      const grade = document.getElementById('grade').value;
      const board = document.getElementById('board').value;
      const subject = document.getElementById('subject').value;
      const chapterName = document.getElementById('chapterName').value;
      const fileInput = document.getElementById('pdfFile');
      const statusMsg = document.getElementById('statusMessage');
      const uploadBtn = document.getElementById('uploadBtn');

      if (!fileInput.files[0]) {
        showStatus('Please select a PDF file.', 'error');
        return;
      }

      const file = fileInput.files[0];
      if (file.type !== 'application/pdf') {
        showStatus('Only PDF files are allowed.', 'error');
        return;
      }

      // Max 10MB to avoid large base64 strings taking too much memory (can be adjusted)
      if (file.size > 20 * 1024 * 1024) {
        showStatus('File size must be under 20MB.', 'error');
        return;
      }

      uploadBtn.disabled = true;
      uploadBtn.textContent = 'Uploading...';
      showStatus('', '');

      const reader = new FileReader();
      reader.onload = async function(event) {
        const pdfDataUrl = event.target.result;

        try {
          const res = await fetch('/api/upload-pdf', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              grade,
              board,
              subject,
              chapterName,
              pdfDataUrl,
              pdfTitle: file.name
            })
          });

          const data = await res.json();
          if (data.success) {
            showStatus('PDF uploaded successfully! URL: ' + data.pdfUrl, 'success');
            document.getElementById('uploadForm').reset();
          } else {
            showStatus('Error: ' + data.error, 'error');
          }
        } catch (error) {
          showStatus('Upload failed. Please try again.', 'error');
        } finally {
          uploadBtn.disabled = false;
          uploadBtn.textContent = 'Upload PDF';
        }
      };

      reader.readAsDataURL(file);
    });

    // YouTube Linking
    document.getElementById('linkYoutubeForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const grade = document.getElementById('ytGrade').value;
      const board = document.getElementById('ytBoard').value;
      const subject = document.getElementById('ytSubject').value;
      const chapterName = document.getElementById('ytChapterName').value;
      const language = document.getElementById('ytLanguage').value;
      const youtubeUrl = document.getElementById('youtubeUrl').value;
      const statusMsg = document.getElementById('ytStatusMessage');
      const linkBtn = document.getElementById('linkBtn');

      linkBtn.disabled = true;
      linkBtn.textContent = 'Linking...';
      showStatus('', '', 'ytStatusMessage');

      try {
        const res = await fetch('/api/link-youtube', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            grade,
            board,
            subject,
            chapterName,
            language,
            youtubeUrl
          })
        });

        const data = await res.json();
        if (data.success) {
          showStatus('Video linked successfully! ID: ' + data.video.youtubeVideoId, 'success', 'ytStatusMessage');
          document.getElementById('linkYoutubeForm').reset();
        } else {
          showStatus('Error: ' + data.error, 'error', 'ytStatusMessage');
        }
      } catch (error) {
        showStatus('Linking failed. Please try again.', 'error', 'ytStatusMessage');
      } finally {
        linkBtn.disabled = false;
        linkBtn.textContent = 'Link Video';
      }
    });

    // Settings
    document.getElementById('settingsForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      const apiKey = document.getElementById('ytApiKeyInput').value;
      const btn = document.getElementById('saveSettingsBtn');
      
      btn.disabled = true;
      btn.textContent = 'Saving...';

      try {
        const res = await fetch('/api/settings', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ key: 'YT_API_KEY', value: apiKey })
        });
        const data = await res.json();
        if (data.success) {
          showStatus('API Key saved successfully!', 'success', 'settingsStatusMessage');
        } else {
          showStatus('Error saving API key.', 'error', 'settingsStatusMessage');
        }
      } catch (e) {
        showStatus('Failed to save settings.', 'error', 'settingsStatusMessage');
      } finally {
        btn.disabled = false;
        btn.textContent = 'Save Settings';
      }
    });

    // Load initial settings
    async function loadSettings() {
      try {
        const res = await fetch('/api/settings');
        const data = await res.json();
        if (data.YT_API_KEY) {
          document.getElementById('ytApiKeyInput').placeholder = 'API Key is set (●●●●●●●●)';
        }
      } catch (e) {}
    }
    loadSettings();

    function showStatus(msg, type, elementId = 'statusMessage') {
      const statusEl = document.getElementById(elementId);
      if (!msg) {
        statusEl.style.display = 'none';
        return;
      }
      statusEl.textContent = msg;
      statusEl.className = 'status-msg ' + (type === 'success' ? 'status-success' : 'status-error');
      statusEl.style.display = 'block';
    }
  </script>
</body>
</html>
