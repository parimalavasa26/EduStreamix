<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Study <%= displaySubject || '' %> chapters on EduStreamix." />
  <title>
    <%= displaySubject || 'Study' %> — EduStreamix
  </title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Outfit:wght@400;500;600;700;800&display=swap"
    rel="stylesheet" />
  <link rel="stylesheet" href="/css/style.css" />
</head>

<body class="study-body">

  <nav class="navbar scrolled" id="navbar">
    <a href="/" class="nav-brand">
      <span class="brand-icon">🎓</span>
      <span class="brand-text">EduStreami<span class="brand-x">x</span></span>
    </a>
    <div class="nav-links">
      <a href="/">Home</a>
      <div class="nav-lang-picker">
        <button class="lang-picker-btn">
          <span id="current-lang-name">English</span>
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
        </button>
        <div class="lang-dropdown">
          <a href="#" class="lang-option" onclick="changeAppLang('English')"><span>English</span></a>
          <a href="#" class="lang-option" onclick="changeAppLang('Hindi')"><span>Hindi</span> <span>हिंदी</span></a>
          <a href="#" class="lang-option" onclick="changeAppLang('Telugu')"><span>Telugu</span> <span>తెలుగు</span></a>
          <a href="#" class="lang-option" onclick="changeAppLang('Kannada')"><span>Kannada</span> <span>ಕನ್ನಡ</span></a>
          <a href="#" class="lang-option" onclick="changeAppLang('Tamil')"><span>Tamil</span> <span>தமிழ்</span></a>
          <a href="#" class="lang-option" onclick="changeAppLang('Malayalam')"><span>Malayalam</span> <span>മലയാളం</span></a>
          <a href="#" class="lang-option" onclick="changeAppLang('Odia')"><span>Odia</span> <span>ଓଡ଼ିଆ</span></a>
        </div>
      </div>
    </div>
  </nav>

  <main class="study-main">
    <div class="study-container">

      <!-- HEADER -->
      <div class="study-page-header">
        <a href="/subjects?grade=<%= selectedGrade %>&board=<%= selectedBoard %>&language=<%= selectedLanguage %>"
          class="back-home-link" id="back-to-subjects-link" data-i18n="Back to Subjects">← Back to Subjects</a>
        <h1 class="study-page-title"><span class="hero-highlight" id="subject-display">
            <%= displaySubject || 'Subject' %>
          </span></h1>
      </div>

      <!-- CHAPTERS -->
      <div class="chapters-section" id="chapters-section">
        <div class="chapters-list" id="chapters-list">
          <!-- Filled by JS -->
        </div>
      </div>



      <!-- VIDEO PLAYER (hidden initially) -->
      <div class="video-section" id="video-section" style="display:none;">
        <div class="video-top-bar">
          <button class="back-link" id="back-from-video" data-i18n="Back to Chapters">← Back to Chapters</button>
        </div>
        <h2 class="video-title" id="video-title">Loading...</h2>
        <div class="video-meta" id="video-meta"></div>
        <div class="video-wrapper" id="video-wrapper">
          <div class="video-loader" id="video-loader">
            <div class="loader-spinner"></div>
            <p data-i18n="Finding the best video...">Finding the best video...</p>
          </div>
          <div id="video-iframe-container"
            style="display:none; position:absolute; top:0; left:0; width:100%; height:100%;"></div>
        </div>



        <!-- AI Quiz -->
        <div class="quiz-section" id="quiz-section" style="display:none;">
          <div class="quiz-header">
            <span>📝 Chapter Quiz</span>
            <span class="quiz-ai-badge">✨ AI Generated</span>
          </div>

          <!-- Generate bar -->
          <div class="quiz-gen-bar" id="quiz-gen-bar">
            <label for="quiz-count-sel" style="font-size:.88rem;font-weight:600;color:var(--text-secondary);">Questions:</label>
            <select class="quiz-count-select" id="quiz-count-sel">
              <option value="5">5</option>
              <option value="10" selected>10</option>
              <option value="15">15</option>
              <option value="20">20</option>
            </select>
            <button class="quiz-generate-btn" id="quiz-generate-btn">
              🤖 Generate Quiz
            </button>
          </div>

          <!-- Timer bar (hidden until quiz active) -->
          <div class="quiz-timer-bar" id="quiz-timer-bar" style="display:none;">
            ⏱ Estimated time: <span class="quiz-timer-val" id="quiz-timer-val">—</span>
            &nbsp;|&nbsp; ✅ Your time: <span class="quiz-timer-val" id="quiz-elapsed-val">0:00</span>
          </div>

          <div class="quiz-body" id="quiz-body"></div>

          <div class="quiz-actions" id="quiz-actions" style="display:none;">
            <button class="quiz-submit-btn" id="quiz-submit-btn">Submit Answers</button>
          </div>
          <div class="quiz-result" id="quiz-result" style="display:none;"></div>
          <button class="quiz-retake-btn" id="quiz-retake-btn" style="display:none;">🔄 Regenerate Quiz</button>
        </div>


      </div>

    </div>
  </main>

  <footer class="footer">
    <div class="footer-inner">
      <span class="footer-brand">🎓 EduStreami<span class="brand-x">x</span></span>
      <span class="footer-copy">&copy; 2026 EduStreamix. Built for learners.</span>
    </div>
  </footer>

  <script>
    window.__GRADE__ = '<%= selectedGrade || 8 %>';
    window.__BOARD__ = '<%= selectedBoard || "CBSE" %>';
    window.__SUBJECT__ = '<%= selectedSubject || "" %>';
    window.__DISPLAY_SUBJECT__ = '<%= displaySubject || "" %>';
    window.__LANGUAGE__ = '<%= selectedLanguage || "English" %>';
  </script>
  <script src="/js/quizData.js"></script>
  <script src="/js/i18n.js"></script>
  <script src="/js/app.js"></script>
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const display = document.getElementById('nav-lang-display');
      if (display) {
        const lang = localStorage.getItem('appLang') || 'English';
        const languageNames = {
          'English': 'English',
          'Hindi': 'हिंदी',
          'Telugu': 'తెలుగు',
          'Tamil': 'தமிழ்',
          'Kannada': 'ಕನ್ನಡ',
          'Malayalam': 'മലയാളം'
        };
        display.textContent = languageNames[lang] || lang;
      }
    });
  </script>
</body>

</html>