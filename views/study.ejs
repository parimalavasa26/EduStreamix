<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Study Class <%= selectedGrade || '' %> subjects and chapters on EduStreamix." />
  <title>Class <%= selectedGrade || '' %> — EduStreamix</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body class="study-body">

  <nav class="navbar scrolled" id="navbar">
    <a href="/" class="nav-brand">
      <span class="brand-icon">🎓</span>
      <span class="brand-text">EduStreami<span class="brand-x">x</span></span>
    </a>
    <div class="nav-links">
      <a href="/">Home</a>
    </div>
  </nav>

  <main class="study-main">
    <div class="study-container">

      <!-- HEADER -->
      <div class="study-page-header">
        <a href="/" class="back-home-link">← Back to Classes</a>
        <h1 class="study-page-title">Class <span class="hero-highlight" id="grade-display"><%= selectedGrade || '8' %></span></h1>
        <p class="study-page-desc">Select a subject, then pick a chapter to start watching</p>
      </div>

      <!-- BOARD SELECTOR (compact) -->
      <div class="board-bar" id="board-bar">
        <button class="board-tab active" data-board="CBSE">CBSE</button>
        <button class="board-tab" data-board="SSC">SSC</button>
        <button class="board-tab" data-board="ICSE">ICSE</button>
      </div>

      <!-- SUBJECTS -->
      <div class="subjects-section" id="subjects-section">
        <div class="subjects-grid" id="subjects-grid">
          <!-- Filled by JS -->
        </div>
      </div>

      <!-- CHAPTERS (hidden initially) -->
      <div class="chapters-section" id="chapters-section" style="display:none;">
        <div class="chapters-header">
          <button class="back-link" id="back-to-subjects">← Back to Subjects</button>
          <h2 class="chapters-title" id="chapters-title">Chapters</h2>
        </div>
        <div class="chapters-list" id="chapters-list">
          <!-- Filled by JS -->
        </div>
      </div>

      <!-- VIDEO PLAYER (hidden initially) -->
      <div class="video-section" id="video-section" style="display:none;">
        <div class="video-top-bar">
          <button class="back-link" id="back-to-chapters">← Back to Chapters</button>
        </div>
        <h2 class="video-title" id="video-title">Loading...</h2>
        <div class="video-meta" id="video-meta"></div>
        <div class="video-wrapper" id="video-wrapper">
          <div class="video-loader" id="video-loader">
            <div class="loader-spinner"></div>
            <p>Finding the best video...</p>
          </div>
          <iframe id="video-iframe" src="" title="EduStreamix Video Player" frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen style="display:none;"></iframe>
        </div>

        <!-- AI Summary -->
        <div class="ai-summary-box" id="ai-summary" style="display:none;">
          <div class="ai-summary-header">
            <span>✨ AI Summary</span>
          </div>
          <div class="ai-summary-content" id="ai-summary-content"></div>
        </div>

        <!-- Quiz -->
        <div class="quiz-section" id="quiz-section" style="display:none;">
          <div class="quiz-header">
            <span>📝 Quick Quiz</span>
          </div>
          <div class="quiz-body" id="quiz-body"></div>
          <div class="quiz-actions" id="quiz-actions" style="display:none;">
            <button class="quiz-submit-btn" id="quiz-submit-btn">Submit Answers</button>
          </div>
          <div class="quiz-result" id="quiz-result" style="display:none;"></div>
          <button class="quiz-retake-btn" id="quiz-retake-btn" style="display:none;">🔄 Retake Quiz</button>
        </div>
      </div>

    </div>
  </main>

  <footer class="footer">
    <div class="footer-inner">
      <span class="footer-brand">🎓 EduStreami<span class="brand-x">x</span></span>
      <span class="footer-copy">&copy; 2026 EduStreamix. Built for learners.</span>
    </div>
  </footer>

  <script>
    window.__GRADE__ = <%= selectedGrade || 8 %>;
    window.__BOARD__ = '<%= selectedBoard || "CBSE" %>';
  </script>
  <script src="/js/quizData.js"></script>
  <script src="/js/app.js"></script>
</body>
</html>
