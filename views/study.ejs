<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Study <%= selectedSubject || '' %> chapters on EduStreamix." />
  <title><%= selectedSubject || 'Study' %> — EduStreamix</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body class="study-body">

  <nav class="navbar scrolled" id="navbar">
    <a href="/" class="nav-brand">
      <span class="brand-icon">🎓</span>
      <span class="brand-text">EduStreami<span class="brand-x">x</span></span>
    </a>
    <div class="nav-links">
      <select id="nav-lang-switcher" class="nav-lang-switcher">
        <option value="English">English</option>
        <option value="Hindi">Hindi</option>
        <option value="Telugu">Telugu</option>
        <option value="Tamil">Tamil</option>
        <option value="Kannada">Kannada</option>
        <option value="Malayalam">Malayalam</option>
      </select>
      <a href="/">Home</a>
    </div>
  </nav>

  <main class="study-main">
    <div class="study-container">

      <!-- HEADER -->
      <div class="study-page-header">
        <a href="/subjects?grade=<%= selectedGrade %>&board=<%= selectedBoard %>&language=<%= selectedLanguage %>" class="back-home-link" id="back-to-subjects-link" data-i18n="Back to Subjects">← Back to Subjects</a>
        <h1 class="study-page-title"><span class="hero-highlight" id="subject-display"><%= selectedSubject || 'Subject' %></span></h1>
      </div>

      <!-- CHAPTERS -->
      <div class="chapters-section" id="chapters-section">
        <div class="chapters-list" id="chapters-list">
          <!-- Filled by JS -->
        </div>
      </div>



      <!-- VIDEO PLAYER (hidden initially) -->
      <div class="video-section" id="video-section" style="display:none;">
        <div class="video-top-bar">
          <button class="back-link" id="back-from-video" data-i18n="Back to Chapters">← Back to Chapters</button>
        </div>
        <h2 class="video-title" id="video-title">Loading...</h2>
        <div class="video-meta" id="video-meta"></div>
        <div class="video-wrapper" id="video-wrapper">
          <div class="video-loader" id="video-loader">
            <div class="loader-spinner"></div>
            <p data-i18n="Finding the best video...">Finding the best video...</p>
          </div>
          <div id="video-iframe-container" style="display:none; position:absolute; top:0; left:0; width:100%; height:100%;"></div>
        </div>

        <!-- Key Moments -->
        <div class="key-moments-section" id="key-moments" style="display:none;">
          <div class="key-moments-header">
            <span data-i18n="Key Moments">⏱️ Key Moments</span>
          </div>
          <div class="key-moments-list" id="key-moments-list"></div>
        </div>



        <!-- Quiz -->
        <div class="quiz-section" id="quiz-section" style="display:none;">
          <div class="quiz-header">
            <span data-i18n="Quick Quiz">📝 Quick Quiz</span>
          </div>
          <div class="quiz-body" id="quiz-body"></div>
          <div class="quiz-actions" id="quiz-actions" style="display:none;">
            <button class="quiz-submit-btn" id="quiz-submit-btn" data-i18n="Submit Answers">Submit Answers</button>
          </div>
          <div class="quiz-result" id="quiz-result" style="display:none;"></div>
          <button class="quiz-retake-btn" id="quiz-retake-btn" style="display:none;" data-i18n="Retake Quiz">🔄 Retake Quiz</button>
        </div>
        

      </div>

    </div>
  </main>

  <footer class="footer">
    <div class="footer-inner">
      <span class="footer-brand">🎓 EduStreami<span class="brand-x">x</span></span>
      <span class="footer-copy">&copy; 2026 EduStreamix. Built for learners.</span>
    </div>
  </footer>

  <script>
    window.__GRADE__   = <%= selectedGrade || 8 %>;
    window.__BOARD__   = '<%= selectedBoard || "CBSE" %>';
    window.__SUBJECT__ = '<%= selectedSubject || "" %>';
    window.__LANGUAGE__ = '<%= selectedLanguage || "English" %>';
  </script>
  <script src="/js/quizData.js"></script>
  <script src="/js/i18n.js"></script>
  <script src="/js/app.js"></script>
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const switcher = document.getElementById('nav-lang-switcher');
      if (switcher) {
        switcher.value = localStorage.getItem('appLang') || 'English';
        switcher.addEventListener('change', (e) => {
          if (window.applyLanguage) applyLanguage(e.target.value);
        });
      }
    });
  </script>
</body>
</html>
