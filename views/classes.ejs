<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Choose your class on EduStreamix to start learning." />
  <title>Choose Your Class — EduStreamix</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body class="step-body">

  <nav class="navbar scrolled" id="navbar">
    <a href="/" class="nav-brand">
      <span class="brand-icon">🎓</span>
      <span class="brand-text">EduStreami<span class="brand-x">x</span></span>
    </a>
    <div class="nav-links">
      <span class="nav-lang-display" id="nav-lang-display">English</span>
      <a href="/">Home</a>
    </div>
  </nav>

  <main class="step-main">
    <div class="step-container">

      <!-- Progress indicator -->
      <div class="step-progress" id="step-progress">
        <div class="step-dot completed" data-step="1">
          <span class="step-dot-inner">1</span>
          <span class="step-dot-label">Language</span>
        </div>
        <div class="step-line filled"></div>
        <div class="step-dot active" data-step="2">
          <span class="step-dot-inner">2</span>
          <span class="step-dot-label">Class</span>
        </div>
        <div class="step-line"></div>
        <div class="step-dot" data-step="3">
          <span class="step-dot-inner">3</span>
          <span class="step-dot-label">Board</span>
        </div>
        <div class="step-line"></div>
        <div class="step-dot" data-step="4">
          <span class="step-dot-inner">4</span>
          <span class="step-dot-label">Subjects</span>
        </div>
      </div>

      <div class="step-header">
        <a href="/languages" class="back-step-link" id="back-to-languages" data-i18n="Back to Languages">← Back to Languages</a>
        <h1 class="step-title"><span data-i18n="Select Class">Choose Your Class</span></h1>
        <p class="step-subtitle" data-i18n="Select your grade to begin your learning journey">Select your grade to begin your learning journey</p>
      </div>

      <div class="class-grid" id="class-grid">
        <a href="/boards?grade=8" class="class-card" id="class-card-8">
          <div class="class-card-glow"></div>
          <span class="class-stage-icon">🌱</span>
          <h3 class="class-card-title" data-i18n="Class 8">Class 8</h3>
          <p class="class-card-label" data-i18n="Foundation Stage">Foundation Stage</p>
          <span class="class-card-arrow">→</span>
        </a>
        <a href="/boards?grade=9" class="class-card" id="class-card-9">
          <div class="class-card-glow"></div>
          <span class="class-stage-icon">🌿</span>
          <h3 class="class-card-title" data-i18n="Class 9">Class 9</h3>
          <p class="class-card-label" data-i18n="Growth Stage">Growth Stage</p>
          <span class="class-card-arrow">→</span>
        </a>
        <a href="/boards?grade=10" class="class-card" id="class-card-10">
          <div class="class-card-glow"></div>
          <span class="class-stage-icon">🌳</span>
          <h3 class="class-card-title" data-i18n="Class 10">Class 10</h3>
          <p class="class-card-label" data-i18n="Mastery Stage">Mastery Stage</p>
          <span class="class-card-arrow">→</span>
        </a>
      </div>

    </div>
  </main>

  <footer class="footer">
    <div class="footer-inner">
      <span class="footer-brand">🎓 EduStreami<span class="brand-x">x</span></span>
      <span class="footer-copy">&copy; 2026 EduStreamix. Built for learners.</span>
    </div>
  </footer>

  <script src="/js/i18n.js"></script>
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const display = document.getElementById('nav-lang-display');
      if (display) {
        const lang = localStorage.getItem('appLang') || 'English';
        const languageNames = {
          'English': 'English',
          'Hindi': 'हिंदी',
          'Telugu': 'తెలుగు',
          'Tamil': 'தமிழ்',
          'Kannada': 'ಕನ್ನಡ',
          'Malayalam': 'മലയാളം'
        };
        display.textContent = languageNames[lang] || lang;
      }
    });
  </script>
</body>
</html>
