<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Select your preferred language — EduStreamix." />
  <title>Select Language — EduStreamix</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Outfit:wght@400;500;600;700;800&family=Cinzel:wght@400;700&family=Dancing+Script:wght@400;700&family=Shadows+Into+Light&display=swap"
    rel="stylesheet" />
  <link rel="stylesheet" href="/css/style.css" />
</head>

<body class="step-body">

  <nav class="navbar scrolled" id="navbar">
    <a href="/" class="nav-brand">
      <span class="brand-icon">🎓</span>
      <span class="brand-text">EduStreami<span class="brand-x">x</span></span>
    </a>
    <div class="nav-links">
      <select id="nav-lang-switcher" class="nav-lang-switcher">
        <option value="English">English</option>
        <option value="Hindi">Hindi</option>
        <option value="Telugu">Telugu</option>
        <option value="Tamil">Tamil</option>
        <option value="Kannada">Kannada</option>
        <option value="Malayalam">Malayalam</option>
      </select>
      <a href="/">Home</a>
    </div>
  </nav>

  <main class="step-main">
    <div class="step-container">

      <!-- Progress indicator -->
      <div class="step-progress" id="step-progress">
        <div class="step-dot active" data-step="1">
          <span class="step-dot-inner">1</span>
          <span class="step-dot-label">Language</span>
        </div>
        <div class="step-line"></div>
        <div class="step-dot" data-step="2">
          <span class="step-dot-inner">2</span>
          <span class="step-dot-label">Board</span>
        </div>
        <div class="step-line"></div>
        <div class="step-dot" data-step="3">
          <span class="step-dot-inner">3</span>
          <span class="step-dot-label">Subjects</span>
        </div>
      </div>

      <div class="step-header">
        <a href="/" class="back-step-link" id="back-to-boards">← Back to Home</a>
        <h1 class="step-title"><span>Select Language</span></h1>
        <p class="step-subtitle">Choose your preferred language for your lessons</p>
      </div>

      <div class="board-grid" id="language-grid">
        <% const langs=['English', 'Hindi' , 'Telugu' , 'Tamil' , 'Kannada' , 'Malayalam' ]; %>
          <% langs.forEach(lang=> { %>
            <a href="#" class="board-card language-selector" data-lang="<%= lang %>">
              <div class="board-card-glow"></div>
              <span class="board-icon">🌐</span>
              <h3 class="board-card-title">
                <%= lang %>
              </h3>
              <span class="board-card-arrow">→</span>
            </a>
            <% }) %>
      </div>

    </div>
  </main>

  <footer class="footer">
    <div class="footer-inner">
      <span class="footer-brand">🎓 EduStreami<span class="brand-x">x</span></span>
      <span class="footer-copy">&copy; 2026 EduStreamix. Built for learners.</span>
    </div>
  </footer>

  <script src="/js/i18n.js"></script>
  <script>
    // Language code map for Google Translate (deprecated but kept for structure)
    const langCodesLoc = {
      'English': 'en',
      'Hindi': 'hi',
      'Telugu': 'te',
      'Tamil': 'ta',
      'Kannada': 'kn',
      'Malayalam': 'ml'
    };

    document.querySelectorAll('.language-selector').forEach(el => {
      el.addEventListener('click', function (e) {
        e.preventDefault();
        const selectedLang = this.getAttribute('data-lang');

        // Use our new instant system instead of Google Translate cookies
        if (window.applyLanguage) applyLanguage(selectedLang);
        else localStorage.setItem('appLang', selectedLang);

        // Redirect to boards step
        window.location.href = '/boards';
      });
    });

    document.addEventListener('DOMContentLoaded', () => {
      const switcher = document.getElementById('nav-lang-switcher');
      if (switcher) {
        switcher.value = localStorage.getItem('appLang') || 'English';
        switcher.addEventListener('change', (e) => {
          if (window.applyLanguage) applyLanguage(e.target.value);
        });
      }
    });
  </script>
</body>

</html>